# FoodDraft — Caddy config. The Node app runs on 127.0.0.1:4100.
# Caddy auto-provisions HTTPS and proxies WebSockets automatically — no extra
# directives needed for the live draft.

# ── Option A: subdomain (easiest — same pattern as your other sites) ───────────
#   Needs a DNS A record: fooddraft.payrollgm.com -> your server IP.
fooddraft.payrollgm.com {
    reverse_proxy 127.0.0.1:4100
}

# ── Option B: subpath — restructure your existing payrollgm.com block like this.
#   `handle_path` strips the /fooddraft prefix before proxying. Using mutually
#   exclusive `handle` blocks (/fooddraft first) guarantees it wins over any
#   site-wide directive your other app uses.
#
# payrollgm.com {
#     handle_path /fooddraft/* {
#         reverse_proxy 127.0.0.1:4100
#     }
#
#     handle {
#         # ... move ALL your existing payrollgm.com directives in here ...
#     }
# }
